APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disco donde Filament guarda los archivos subidos (public = local; s3 = bucket S3/R2)
# FILAMENT_UPLOAD_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Garage / MinIO / S3-compatible (ej. http://74.208.61.170:3900)
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
# URL pública del bucket (ej. http://74.208.61.170:3900/uploads)
AWS_URL=

# Disco por defecto y subidas Filament (adjuntos artículos, términos, etc.)
FILESYSTEM_DISK=s3
FILAMENT_UPLOAD_DISK=s3

VITE_APP_NAME="${APP_NAME}"

# Firebase (notificaciones push y Admin SDK)
# Por defecto usa: storage/app/firebase/service-account-key.json
#
# Durante composer install / build (opcional): SKIP_FIREBASE_BOOT=true
# Recomendado (bucket privado): disco con credenciales AWS/R2/S3
# FIREBASE_CREDENTIALS_STORAGE_PATH=firebase/service-account-key.json
# FIREBASE_CREDENTIALS_DISK=s3
# Solo para bucket público (no recomendado para credenciales): URL directa
# FIREBASE_CREDENTIALS_REMOTE_URL=https://tu-bucket...
#
# Ruta manual al JSON (si no quieres descarga automática):
# FIREBASE_CREDENTIALS=
# Variables individuales o Base64 (ver documentación):
# ID del proyecto Firebase (debe coincidir con project_id del JSON de la cuenta de servicio)
# Proyecto y Sender ID (número) de Firebase Console → Configuración del proyecto
# FIREBASE_PROJECT_ID=romanocc-9a797
# FIREBASE_PROJECT=romanocc-9a797
# FIREBASE_SENDER_ID=475003090229
# FIREBASE_CREDENTIALS_BASE64=
